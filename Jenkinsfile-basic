pipeline {
    agent any

    stages {
        stage('test') {
            steps {
                echo 'testing the appn'
                echo "Executing the piplene in $BRANCH_NAME"
            }
        }
        stage('build') {
            when{
                expression{
                    BRANCH_NAME == 'master'
                }
            }
            steps {
                script{
                    echo 'building the appn'
                }
            }
        }

        stage('deploy') {
            when{
                expression{
                    BRANCH_NAME == 'master'
                }
            }
            steps {
                echo 'deploying the appn'
            }
        }
    }
}
